        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./android/app/src/main/res/mipmap-xxxhdpi/ic_launcher.png"
    },
    "description": "YMS Axioma - Sistema de Gerenciamento de Pátios e Operações de Motoristas. Desenvolvido pela Axioma Dados.",
    "owner": "axioma-dados"
